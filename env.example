# ==============================================
# MOTACARE — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ==============================================

# --- App ---
NODE_ENV=development
APP_NAME=motacare

# --- Auth Service ---
AUTH_SERVICE_PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# --- Vehicle Service ---
VEHICLE_SERVICE_PORT=3002
VEHICLE_HASH_SECRET=your-vehicle-hash-secret-change-in-production

# --- Inspection Service ---
INSPECTION_SERVICE_PORT=3003

# --- API Gateway ---
API_GATEWAY_PORT=3000

# --- Subscription Service ---
SUBSCRIPTION_DB_NAME=motacare_subscriptions
SUBSCRIPTION_SERVICE_PORT=3007

# --- Web Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3000
WEB_PORT=3005

# --- PostgreSQL (main database) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=motacare
POSTGRES_PASSWORD=motacare_dev_password
POSTGRES_DB=motacare

# Per-service DB names (all on same Postgres instance in dev)
AUTH_DB_NAME=motacare_auth
VEHICLE_DB_NAME=motacare_vehicles
INSPECTION_DB_NAME=motacare_inspections
FIX_JOBS_DB_NAME=motacare_fixjobs

# --- Redis (sessions, timers, queues) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Email (alerts) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
EMAIL_FROM=noreply@motacare.app

# --- Anthropic Claude API (Phase 2) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Stripe (Phase 4) ---
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_PRO_MONTHLY:15
STRIPE_PRICE_PRO_YEARLY=999
STRIPE_PRICE_WORKSHOP_MONTHLY=25
STRIPE_PRICE_WORKSHOP_YEARLY=500
